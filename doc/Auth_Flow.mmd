%%{init: {"theme": "base", "themeVariables": {"primaryColor": "#1e1e2e", "primaryBorderColor": "#89b4fa", "primaryTextColor": "#cdd6f4", "lineColor": "#89b4fa", "secondaryColor": "#313244", "tertiaryColor": "#45475a", "fontFamily": "Arial", "fontSize": "14px", "noteBkgColor": "#313244", "noteTextColor": "#cdd6f4", "activationBkgColor": "#45475a", "sequenceNumberColor": "#cdd6f4"}}}%%

sequenceDiagram
    autonumber

    actor Browser as 🌐 Browser / Postman
    participant Filter as JwtAuthenticationFilter
    participant AC as AuthController
    participant AS as AuthServiceImpl
    participant AdminRepo as admin_users (DB)
    participant ClientRepo as client_users (DB)
    participant TS as TokenServiceImpl
    participant RT as refresh_tokens (DB)

    %% ════════════════════════════════════════════
    %% SECTION 1 — LOGIN
    %% ════════════════════════════════════════════

    Note over Browser,RT: ══════════════════════ 1. LOGIN ══════════════════════

    Browser->>Filter: POST /api/v1/auth/login { email, password }
    Note over Filter: /auth/** is public — skips JWT check
    Filter->>AC: pass through

    AC->>AS: login(email, password, response)

    AS->>AdminRepo: SELECT * FROM admin_users WHERE email = ?
    AdminRepo-->>AS: AdminUser OR null

    alt email found in admin_users
        AS->>AS: ✅ BCrypt.matches(password, passwordHash)
        Note over AS: role = "ADMIN"
    else not found in admin_users
        AS->>ClientRepo: SELECT * FROM client_users WHERE email = ?
        ClientRepo-->>AS: ClientUser OR null
        alt email found in client_users
            AS->>AS: ✅ BCrypt.matches(password, passwordHash)
            Note over AS: role = "CLIENT"
        else not found anywhere
            AS-->>AC: ❌ throw UnauthorizedException
            AC-->>Browser: 401 { "Invalid email or password" }
        end
    end

    AS->>TS: setAccessTokenCookie(email, role, response)
    Note over TS: generateAccessToken() → JWT<br/>{ sub: email, role: ADMIN/CLIENT, exp: now+15min }
    TS-->>Browser: Set-Cookie: access_token=eyJ...<br/>HttpOnly; Path=/; Max-Age=900

    AS->>TS: createAndSetRefreshToken(email, role, response)
    TS->>TS: generate random UUID token
    TS->>TS: hash = SHA-256(rawToken)
    TS->>RT: INSERT (token_hash, email, role, expires_at=now+7d, revoked=false)
    TS-->>Browser: Set-Cookie: refresh_token=raw-uuid<br/>HttpOnly; Path=/api/v1/auth; Max-Age=604800

    AC-->>Browser: 200 OK { role, email, fullName }<br/>⚠️ NO token in response body

    Note over Browser: Browser stores both cookies internally<br/>JS cannot read them (HttpOnly ✅ XSS-safe)

    %% ════════════════════════════════════════════
    %% SECTION 2 — AUTHENTICATED REQUEST
    %% ════════════════════════════════════════════

    Note over Browser,RT: ══════════════════ 2. AUTHENTICATED REQUEST ══════════════════

    Browser->>Filter: GET /api/v1/admin/clients<br/>Cookie: access_token=eyJ... (auto-sent by browser)
    Note over Filter: Reads access_token from Cookie header<br/>(NOT Authorization header)

    Filter->>Filter: jwtService.isAccessTokenValid(token)

    alt token valid & not expired
        Filter->>Filter: extractEmail() → "vivek@hor.com"<br/>extractRole()  → "ADMIN"
        Filter->>Filter: set SecurityContext → ROLE_ADMIN
        Filter->>AC: chain.doFilter() → proceed to controller
        AC-->>Browser: 200 OK { data }
    else token expired (> 15 min)
        Filter-->>Browser: 401 { "Access token expired — please refresh" }
    end

    %% ════════════════════════════════════════════
    %% SECTION 3 — TOKEN REFRESH
    %% ════════════════════════════════════════════

    Note over Browser,RT: ══════════════════════ 3. REFRESH ══════════════════════

    Note over Browser: access_token expired<br/>Frontend calls /refresh

    Browser->>Filter: POST /api/v1/auth/refresh<br/>Cookie: refresh_token=raw-uuid (auto-sent, Path matches)
    Note over Filter: /auth/refresh is public — skips JWT check
    Filter->>AC: pass through

    AC->>AS: refresh(request, response)
    AS->>TS: validateRefreshTokenFromCookie(request)
    TS->>TS: extract refresh_token cookie value
    TS->>RT: SELECT * FROM refresh_tokens<br/>WHERE token_hash = SHA256(raw-uuid)

    alt token found, not revoked, not expired
        TS->>RT: UPDATE SET revoked = true (old token dead)
        TS->>RT: INSERT new refresh token (rotation 🔄)
        TS-->>Browser: Set-Cookie: refresh_token=new-uuid<br/>HttpOnly; Path=/api/v1/auth; Max-Age=604800
        AS->>TS: setAccessTokenCookie(email, role, response)
        TS-->>Browser: Set-Cookie: access_token=eyJ-new<br/>HttpOnly; Path=/; Max-Age=900
        AC-->>Browser: 200 OK { role, email }
    else revoked / expired / not found
        AS-->>AC: ❌ throw UnauthorizedException
        AC-->>Browser: 401 { "Refresh token has expired" }<br/>→ User must login again
    end

    %% ════════════════════════════════════════════
    %% SECTION 4 — LOGOUT
    %% ════════════════════════════════════════════

    Note over Browser,RT: ══════════════════════ 4. LOGOUT ══════════════════════

    Browser->>Filter: POST /api/v1/auth/logout<br/>Cookie: refresh_token=new-uuid (auto-sent)
    Note over Filter: /auth/logout is public — skips JWT check
    Filter->>AC: pass through

    AC->>AS: logout(request, response)
    AS->>TS: validateRefreshTokenFromCookie(request)
    TS->>RT: SELECT ... WHERE token_hash = SHA256(new-uuid)

    AS->>TS: revokeAllAndClearCookies(email, response)
    TS->>RT: UPDATE SET revoked = true<br/>WHERE user_email = ? (ALL sessions killed)
    TS-->>Browser: Set-Cookie: access_token=; Max-Age=0 🗑️
    TS-->>Browser: Set-Cookie: refresh_token=; Max-Age=0 🗑️

    AC-->>Browser: 200 OK { "Logged out successfully" }

    Note over Browser: Both cookies deleted from browser<br/>Next request → no cookie → 401 Unauthorized
